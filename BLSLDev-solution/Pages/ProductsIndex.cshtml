        $('#btnFinishUpload').hide();
        $('#btnUploadMore').hide();
        $('#btnCancelUpload').show();

        // 清空文件输入
        $('#imageFileInput').val('');
    }

    // 完成批量上传
    function finishBatchUpload() {
        $('#batchUploadModal').modal('hide');
    }

