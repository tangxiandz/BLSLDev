﻿<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 拌料上料管理系统</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
    <style>
        body {
            font-size: 15px;
        }
        .form-group {
            margin-bottom: 1rem;
        }
        .form-control {
            border: 1px solid #ced4da;
            border-radius: 0.25rem;
            box-shadow: inset 0 1px 1px rgba(0, 0, 0, 0.075);
            transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
        }
        .form-control:focus {
            border-color: #80bdff;
            outline: 0;
            box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <div class="navbar-collapse collapse d-sm-inline-flex">
                    <ul class="navbar-nav">
                        <li class="nav-item mr-4">
                            <a class="nav-link" id="nav-material" asp-area="" asp-page="/Material/Index">物料管理</a>
                        </li>
                        <li class="nav-item mr-4">
                            <a class="nav-link" id="nav-bucket" asp-area="" asp-page="/Bucket/Index">桶料管理</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" id="nav-statistics" asp-area="" asp-page="/Statistics/Index">查询统计</a>
                        </li>
                    </ul>
                </div>
                <a class="navbar-brand" asp-area="" asp-page="/Index">拌料上料管理系统</a>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>



    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // 设置菜单选中状态
        $(document).ready(function() {
            var currentPath = window.location.pathname;
            
            // 移除所有菜单的active类和样式
            $('.nav-link').removeClass('active');
            $('.nav-link').css({
                'background-color': '',
                'color': '#6c757d',
                'font-weight': '',
                'padding': '0.5rem 1rem',
                'border-radius': '4px',
                'margin': '0 0.25rem'
            });
            
            // 根据当前路径设置对应的菜单为active
            if (currentPath.includes('/Material')) {
                $('#nav-material').addClass('active');
                $('#nav-material').css({
                    'background-color': '#1E88E5',
                    'color': 'white',
                    'font-weight': 'bold',
                    'padding': '0.5rem 1rem',
                    'border-radius': '4px',
                    'margin': '0 0.25rem'
                });
            } else if (currentPath.includes('/Bucket')) {
                $('#nav-bucket').addClass('active');
                $('#nav-bucket').css({
                    'background-color': '#1E88E5',
                    'color': 'white',
                    'font-weight': 'bold',
                    'padding': '0.5rem 1rem',
                    'border-radius': '4px',
                    'margin': '0 0.25rem'
                });
            } else if (currentPath.includes('/Statistics')) {
                $('#nav-statistics').addClass('active');
                $('#nav-statistics').css({
                    'background-color': '#1E88E5',
                    'color': 'white',
                    'font-weight': 'bold',
                    'padding': '0.5rem 1rem',
                    'border-radius': '4px',
                    'margin': '0 0.25rem'
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
